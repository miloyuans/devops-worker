BOT_TOKEN=123456:replace_me
GROUP_CHAT_IDS=-1001234567890
GROUP_CHAT_TOPICS=-1001234567890:12
APPROVER_USER_IDS=123456789,987654321
WEB_ADDR=:8080
DATA_DIR=./data
APP_TIMEZONE=Asia/Dubai
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Telegram 工作提醒里的排班工单地址，可为空
WORK_ORDER_URL=https://cs.123.com

# 每日排班明细自动发送时间，使用 APP_TIMEZONE 时区，默认 09:00
DAILY_REPORT_TIME=09:00

# SSO 默认禁用。请用 admin 登录后在 Web 页面 /sso-settings 中配置并启用。
# 以下环境变量仅保留兼容旧部署，不再自动启用或写入 UI 配置。
SSO_ENABLED=false
