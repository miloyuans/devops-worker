BOT_TOKEN=123456:replace_me
GROUP_CHAT_IDS=-1001234567890
GROUP_CHAT_TOPICS=-1001234567890:12
APPROVER_USER_IDS=123456789,987654321
WEB_ADDR=:8080
DATA_DIR=./data
APP_TIMEZONE=Asia/Dubai
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Telegram 工作提醒里的排班工单地址，可为空
WORK_ORDER_URL=https://cs.123.com

# 每日排班明细自动发送时间，使用 APP_TIMEZONE 时区，默认 09:00
DAILY_REPORT_TIME=09:00

# Keycloak / OIDC SSO，可选。启用后 /login 会出现 SSO 登录入口。
# OIDC_ISSUER_URL 示例: https://keycloak.example.com/realms/devops
SSO_ENABLED=false
OIDC_ISSUER_URL=https://keycloak.example.com/realms/devops
OIDC_CLIENT_ID=devops-worker
OIDC_CLIENT_SECRET=replace_me
OIDC_REDIRECT_URL=https://dwork.abc.om/sso/callback
OIDC_SCOPES=openid profile email
# 命中其中一个用户标识或角色才会授予 admin 权限；普通用户仍可无需登录访问。
SSO_ADMIN_USERS=admin@example.com,admin_username
SSO_ADMIN_ROLES=devops-worker-admin,admin
